# Copy this file to .env and adjust values before running docker compose

DB_USERNAME=tenpo
DB_PASSWORD=tenpo_secret

# Optionally override rate limit / cache TTL
RATE_LIMIT_RPM=3
CACHE_TTL_MINUTES=30

# Enable mock service failure simulation (for testing retry / cache fallback)
MOCK_FAILURE_ENABLED=false
MOCK_FAIL_EVERY_N=2
